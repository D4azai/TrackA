# =============================
# Core
# =============================
DATABASE_URL=postgresql://user:password@localhost:5432/recommendation_db
REDIS_URL=redis://localhost:6379/0

# =============================
# Runtime
# =============================
SERVICE_PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# =============================
# API security / networking
# =============================
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ADMIN_API_KEY=change-this-in-production

# =============================
# Cache
# =============================
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# =============================
# Database pool
# =============================
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# =============================
# Recommendation tuning
# =============================
WEIGHT_POPULARITY=0.25
WEIGHT_HISTORY=0.35
WEIGHT_RECENCY=0.20
WEIGHT_NEWNESS=0.15
WEIGHT_ENGAGEMENT=0.05
MAX_LIMIT=100
MIN_SCORE_THRESHOLD=0.0
RECOMMENDATION_ALGORITHM_VERSION=2026.04.precomputed-v1

# =============================
# Precomputed storage & refresh
# =============================
PRECOMPUTED_STORE_LIMIT=100
PRECOMPUTED_FRESHNESS_SECONDS=1800
SERVE_STALE_PRECOMPUTED=true
SYNC_RECOMPUTE_FALLBACK_ENABLED=
REFRESH_ACTIVE_SELLERS_LOOKBACK_DAYS=30
REFRESH_ACTIVE_SELLERS_LIMIT=500
REFRESH_EVENT_PRIORITY=150
REFRESH_SCHEDULE_PRIORITY=100
REFRESH_MANUAL_PRIORITY=200
REFRESH_MAX_ATTEMPTS=3

# =============================
# Worker (refresh_worker.py / scheduler.py)
# =============================
POLL_INTERVAL_SECONDS=30
WORKER_BATCH_SIZE=10
DRAIN_INTERVAL_MINUTES=5
ENQUEUE_INTERVAL_MINUTES=30
